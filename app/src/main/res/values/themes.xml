<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QYVOS" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/error_red</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.QYVOS.Splash" parent="Theme.QYVOS">
        <item name="android:windowSplashScreenBackground">@color/bg_primary</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.QYVOS.NoActionBar" parent="Theme.QYVOS">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="QyvosCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="QyvosBubble.User">
        <item name="android:background">@drawable/bg_bubble_user</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="QyvosBubble.Assistant">
        <item name="android:background">@drawable/bg_bubble_assistant</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
