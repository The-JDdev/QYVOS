<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_surface">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:text="QYVOS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvStatus"
                    android:text="Ready"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnTogglePanel"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_panel_expand"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="Toggle execution panel"/>

            <ImageButton
                android:id="@+id/btnNewChat"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_new_chat"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="New chat"/>

            <ImageButton
                android:id="@+id/btnClear"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_clear"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="Clear chat"/>

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="Settings"/>

            <ImageButton
                android:id="@+id/btnDeveloper"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_info"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary"
                android:contentDescription="Developer info"/>
        </androidx.appcompat.widget.Toolbar>

        <!-- Browser URL Bar (shown when agent is browsing) -->
        <LinearLayout
            android:id="@+id/browserUrlBar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@color/bg_surface_2"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_browser"
                android:tint="@color/text_secondary"/>
            <TextView
                android:id="@+id/tvBrowserUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/accent_secondary"
                android:singleLine="true"
                android:ellipsize="middle"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- GOD'S EYE: Execution Panel (collapsible) -->
        <LinearLayout
            android:id="@+id/executionPanelContainer"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:background="@color/bg_terminal"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:background="@color/bg_terminal_header"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_green"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ God's Eye — Live Execution"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/terminal_text"
                    android:layout_marginStart="8dp"/>
                <ImageButton
                    android:id="@+id/btnExpandPanel"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_panel_collapse"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/terminal_text"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvExecutionLogs"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:scrollbars="vertical"
                android:background="@color/bg_terminal"/>
        </LinearLayout>

        <!-- Activity badge (shown when panel is closed but logs are streaming) -->
        <View
            android:id="@+id/badgeActivity"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/accent_primary"
            android:visibility="gone"/>

        <!-- Streaming indicator -->
        <TextView
            android:id="@+id/tvStreamingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="italic"
            android:background="@color/bg_surface"
            android:visibility="gone"/>

        <!-- Message List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"
            android:scrollbars="vertical"/>

        <!-- Progress indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:indicatorColor="@color/accent_primary"
            app:trackColor="@color/bg_surface"/>

        <!-- Input Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_surface"
            android:elevation="8dp"
            android:padding="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hint="Ask QYVOS anything..."
                app:boxCornerRadiusTopStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_send"
                app:endIconContentDescription="Send">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="5"
                    android:textColor="@color/text_primary"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="actionSend"/>
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnVoice"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🎤"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Cancel"
                    android:textColor="@color/error_red"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnSend"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Send"
                    android:backgroundTint="@color/accent_primary"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
