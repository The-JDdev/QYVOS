<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_surface"/>

        <!-- Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgDeveloper"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/img_developer"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/accent_primary"/>

                <TextView
                    android:id="@+id/tvDevName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SHS Shobuj (JD Vijay)"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:id="@+id/tvAppVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QYVOS v1.0.0"
                    android:textSize="14sp"
                    android:textColor="@color/accent_primary"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvAppTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Powered by OpenManus AI Engine"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Donation Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="💰 Support the Developer"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"/>

                <!-- WebMoney WMZ -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="WebMoney WMZ" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvWmzAddress" android:text="Z430378899900" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnCopyWmz" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Copy"/>
                </LinearLayout>

                <!-- WebMoney WMT -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="WebMoney WMT" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvWmtAddress" android:text="T202226490170" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnCopyWmt" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Copy"/>
                </LinearLayout>

                <!-- bKash -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/accent_primary"
                    app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tvBkashLabel" android:text="bKash Donation" android:textSize="12sp" android:textColor="@color/accent_tertiary" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvBkashAddress" android:text="Contact for bKash details" android:textSize="13sp" android:textColor="@color/text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <Button android:id="@+id/btnCopyBkash" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Info"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Social Links -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="🔗 Connect"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"/>

                <!-- Telegram -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:text="✈️" android:textSize="20sp" android:layout_width="32dp" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:text="Telegram" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTelegramHandle" android:text="@aamoviesofficial" android:textSize="13sp" android:textColor="@color/info_blue" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnTelegram" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Open" android:textColor="@color/info_blue"/>
                </LinearLayout>

                <!-- Email -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:text="📧" android:textSize="20sp" android:layout_width="32dp" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:text="Email" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvEmailAddress" android:text="The-JDdev.official@gmail.com" android:textSize="13sp" android:textColor="@color/text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnEmail" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textColor="@color/accent_secondary"/>
                </LinearLayout>

                <!-- Facebook -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:text="👤" android:textSize="20sp" android:layout_width="32dp" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:text="Facebook" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvFacebookHandle" android:text="facebook.com/itsshsshobuj" android:textSize="13sp" android:textColor="@color/text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnFacebook" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Visit" android:textColor="@color/info_blue"/>
                </LinearLayout>

                <!-- GitHub -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:text="🐙" android:textSize="20sp" android:layout_width="32dp" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:text="GitHub" android:textSize="11sp" android:textColor="@color/text_secondary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvGithubHandle" android:text="github.com/The-JDdev/QYVOS" android:textSize="13sp" android:textColor="@color/text_primary" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnGithub" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Visit" android:textColor="@color/accent_primary"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
