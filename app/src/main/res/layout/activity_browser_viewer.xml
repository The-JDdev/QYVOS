<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"/>

    <!-- Agent mode badge -->
    <TextView
        android:id="@+id/tvAgentMode"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:text="🤖 AGENT MODE — AI is controlling this browser"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/warning_amber"
        android:gravity="center"
        android:background="@color/bg_terminal_header"
        android:visibility="gone"/>

    <!-- Address Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">

        <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_back" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/text_primary"/>
        <ImageButton android:id="@+id/btnForward" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_forward" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/text_primary"/>
        <ImageButton android:id="@+id/btnRefresh" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_refresh" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/text_primary"/>

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_url_bar"
            android:paddingHorizontal="12dp"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:inputType="textUri"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:layout_marginHorizontal="8dp"
            android:hint="Enter URL"
            android:hintTextColor="@color/text_secondary"/>

        <ImageButton android:id="@+id/btnGo" android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_go" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/accent_primary"/>
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progressTint="@color/accent_primary"
        android:visibility="gone"/>

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
