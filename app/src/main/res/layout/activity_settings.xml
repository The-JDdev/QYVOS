<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_surface"
            app:title="Settings"
            app:titleTextColor="@color/text_primary"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Engine Configuration"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect QYVOS to any OpenAI-compatible AI provider"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Model Presets -->
            <TextView
                android:text="Quick Presets"
                android:textSize="14sp"
                android:textColor="@color/accent_secondary"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <com.google.android.material.chip.Chip android:id="@+id/chipQyvosCloud" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QYVOS Cloud" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipDeepseek" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DeepSeek R1" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipOpenai" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OpenAI GPT-4o" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipClaude" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Claude 3.5" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipGrok" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grok-3" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipGroq" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Groq Llama" app:chipBackgroundColor="@color/bg_surface"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipOllama" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ollama (Local)" app:chipBackgroundColor="@color/bg_surface"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Base URL -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBaseUrl"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Base URL"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textUri"
                    android:hint="https://the-jddev-qyvos-api.hf.space"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Endpoint Path -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEndpoint"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Endpoint Path"
                app:helperText="e.g. api/chat (QYVOS) or chat/completions (OpenAI)"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEndpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textUri"
                    android:hint="api/chat"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- API Key -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilApiKey"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="API Key"
                app:endIconMode="password_toggle"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textPassword"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Model Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilModelName"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Model Name"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etModelName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:hint="qyvos-v1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Advanced Row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMaxTokens"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp"
                    android:hint="Max Tokens"
                    app:boxStrokeColor="@color/accent_primary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxTokens"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTemperature"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp"
                    android:hint="Temperature"
                    app:boxStrokeColor="@color/accent_primary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTemperature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilMaxSteps"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="Max Agent Steps (1-50)"
                app:boxStrokeColor="@color/accent_primary"
                app:hintTextColor="@color/text_secondary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMaxSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Test Result -->
            <TextView
                android:id="@+id/tvTestResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"
                android:visibility="visible"
                android:text=""/>

            <!-- Buttons -->
            <Button
                android:id="@+id/btnTestConnection"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Test Connection"/>

            <Button
                android:id="@+id/btnSave"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Save Settings"
                android:backgroundTint="@color/accent_primary"/>

            <Button
                android:id="@+id/btnResetDefaults"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset to Defaults"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
